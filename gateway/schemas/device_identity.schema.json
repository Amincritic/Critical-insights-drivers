{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://critical-insights.local/schemas/device_identity.schema.json",
  "title": "DeviceIdentity",
  "type": "object",
  "required": ["schema_version", "topic", "unique_device_identifier", "presentation_time"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "topic": { "const": "DeviceIdentity" },
    "unique_device_identifier": { "type": "string", "minLength": 1 },
    "manufacturer": { "type": ["string", "null"] },
    "model": { "type": ["string", "null"] },
    "serial_number": { "type": ["string", "null"] },
    "build": { "type": ["string", "null"] },
    "operating_system": { "type": ["string", "null"] },
    "presentation_time": { "type": "string", "format": "date-time" },
    "gateway_id": { "type": "string" },
    "bed_id": { "type": "string" },
    "vendor": { "type": "string" },
    "protocol": { "type": "string" }
  },
  "additionalProperties": true
}
